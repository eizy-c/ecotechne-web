datasource db {
  provider = "mysql"
}

generator client {
  provider = "prisma-client-js"
}

// Laravel Eloquent Naming Conventions - Primary Keys as model_id

model Role {
  role_id     Int       @id @default(autoincrement())
  name        String    @unique @db.VarChar(50)
  description String?   @db.VarChar(255)
  deleted_at  DateTime?

  users       User[]
  permissions PermissionRole[]

  @@map("role")
}

model PermissionRole {
  permission_id Int
  role_id       Int

  permission Permission @relation(fields: [permission_id], references: [permission_id], onDelete: Cascade)
  role       Role       @relation(fields: [role_id], references: [role_id], onDelete: Cascade)

  @@id([permission_id, role_id])
  @@map("permission_role")
}

model Permission {
  permission_id Int       @id @default(autoincrement())
  name          String    @unique @db.VarChar(100)
  description   String?   @db.VarChar(255)
  deleted_at    DateTime?

  roles PermissionRole[]

  @@map("permission")
}

model User {
  user_id    Int       @id @default(autoincrement())
  email      String    @unique @db.VarChar(255)
  password   String    @db.VarChar(255)
  name       String    @db.VarChar(255)
  deleted_at DateTime?

  role_id   Int
  role      Role       @relation(fields: [role_id], references: [role_id])
  auditLogs AuditLog[]

  @@map("user")
}

model Client {
  client_id Int       @id @default(autoincrement())
  name      String    @db.VarChar(255)
  contact   String?   @db.VarChar(255)
  email     String?   @unique @db.VarChar(255)
  phone     String?   @db.VarChar(50)
  country   String?   @db.VarChar(100)
  created_at DateTime @default(now()) @db.Timestamp(0)

  messages     ContactMessage[]
  productLeads ProductLead[]
  serviceLeads ServiceLead[]

  @@map("client")
}

model Brand {
  brand_id   Int       @id @default(autoincrement())
  name       String    @unique @db.VarChar(255)
  deleted_at DateTime?

  models   VehicleModel[]
  vehicles Vehicle[]

  @@map("brand")
}

model Category {
  category_id Int       @id @default(autoincrement())
  name        String    @unique @db.VarChar(255)
  deleted_at  DateTime?

  categoryProducts CategoryProduct[]

  @@map("category")
}

model VehicleModel {
  vehicle_model_id Int       @id @default(autoincrement())
  name             String    @db.VarChar(100)
  deleted_at       DateTime?

  brand_id Int
  brand    Brand @relation(fields: [brand_id], references: [brand_id], onDelete: Cascade)

  vehicles Vehicle[]

  @@unique([brand_id, name])
  @@map("vehicle_model")
}

model Vehicle {
  vehicle_id Int       @id @default(autoincrement())
  year       String    @db.VarChar(50)
  deleted_at DateTime?

  brand_id Int
  brand    Brand @relation(fields: [brand_id], references: [brand_id])

  vehicle_model_id Int
  model            VehicleModel @relation(fields: [vehicle_model_id], references: [vehicle_model_id])

  vehicleProducts VehicleProduct[]

  @@map("vehicle")
}

model Product {
  product_id Int       @id @default(autoincrement())
  name       String    @db.VarChar(255)
  slug       String    @unique @default(uuid()) @db.VarChar(255)
  stock      Int       @default(0)
  image_url   String?   @db.VarChar(512)
  is_featured Boolean   @default(false)
  deleted_at  DateTime?

  description String?   @db.Text

  images           ImageProduct[]
  categoryProducts CategoryProduct[]
  vehicleProducts  VehicleProduct[]
  productLeads     ProductLead[]

  @@map("product")
}

model ImageProduct {
  image_id   Int
  product_id Int
  
  image      GalleryImage @relation(fields: [image_id], references: [image_id], onDelete: Cascade)
  product    Product      @relation(fields: [product_id], references: [product_id], onDelete: Cascade)
  
  @@id([image_id, product_id])
  @@map("image_product")
}

model CategoryProduct {
  category_id Int
  product_id  Int

  category    Category @relation(fields: [category_id], references: [category_id], onDelete: Cascade)
  product     Product  @relation(fields: [product_id], references: [product_id], onDelete: Cascade)

  @@id([category_id, product_id])
  @@map("category_product")
}

model VehicleProduct {
  vehicle_id Int
  product_id Int

  vehicle    Vehicle @relation(fields: [vehicle_id], references: [vehicle_id], onDelete: Cascade)
  product    Product @relation(fields: [product_id], references: [product_id], onDelete: Cascade)

  @@id([vehicle_id, product_id])
  @@map("vehicle_product")
}

model Service {
  service_id  Int       @id @default(autoincrement())
  name        String    @db.VarChar(255)
  slug        String    @unique @default(uuid()) @db.VarChar(255)
  description String?   @db.Text
  icon        String?   @default("gear") @db.VarChar(50)
  image_url   String?   @db.VarChar(512)
  active      Boolean   @default(true)
  deleted_at  DateTime?

  images       ImageService[]
  serviceLeads ServiceLead[]

  @@map("service")
}

model ImageService {
  image_id   Int
  service_id Int
  
  image      GalleryImage @relation(fields: [image_id], references: [image_id], onDelete: Cascade)
  service    Service      @relation(fields: [service_id], references: [service_id], onDelete: Cascade)
  
  @@id([image_id, service_id])
  @@map("image_service")
}

model Album {
  album_id    Int       @id @default(autoincrement())
  name        String    @db.VarChar(255)
  description String?   @db.Text
  created_at  DateTime  @default(now()) @db.Timestamp(0)
  deleted_at  DateTime?

  images      GalleryImage[]

  @@map("album")
}

model GalleryImage {
  image_id    Int       @id @default(autoincrement())
  image_url   String    @db.VarChar(512)
  description String?   @db.Text
  created_at  DateTime  @default(now()) @db.Timestamp(0)
  
  album_id    Int?
  album       Album?    @relation(fields: [album_id], references: [album_id], onDelete: Cascade)

  products    ImageProduct[]
  services    ImageService[]

  @@map("gallery_image")
}

model ContactMessage {
  message_id Int      @id @default(autoincrement())
  name       String   @db.VarChar(255)
  email      String?  @db.VarChar(255)
  phone      String   @db.VarChar(50)
  country    String?  @db.VarChar(100)
  message    String   @db.Text
  is_read    Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamp(0)

  client_id  Int?
  client     Client?  @relation(fields: [client_id], references: [client_id], onDelete: SetNull)

  @@map("contact_message")
}

model Visit {
  visit_id   Int      @id @default(autoincrement())
  ip_address String   @db.VarChar(45)
  country    String?  @db.VarChar(100)
  city       String?  @db.VarChar(100)
  path       String   @db.VarChar(255)
  user_agent String?  @db.VarChar(255)
  created_at DateTime @default(now()) @db.Timestamp(0)

  @@map("visit")
}

model AuditLog {
  log_id     Int      @id @default(autoincrement())
  user_id    Int?
  action     String   @db.VarChar(50) // CREATE, UPDATE, DELETE, LOGIN
  entity     String   @db.VarChar(100) // Product, User, Role, etc.
  entity_id  Int? // El ID del registro afectado
  details    String?  @db.Text // JSON con detalles de lo modificado
  created_at DateTime @default(now()) @db.Timestamp(0)

  user User? @relation(fields: [user_id], references: [user_id])

  @@map("audit_log")
}

model ProductLead {
  lead_id    Int      @id @default(autoincrement())
  product_id Int
  ip_address String?  @db.VarChar(45)
  country    String?  @db.VarChar(100)
  created_at DateTime @default(now()) @db.Timestamp(0)

  client_id  Int?
  client     Client?  @relation(fields: [client_id], references: [client_id], onDelete: SetNull)

  product Product @relation(fields: [product_id], references: [product_id], onDelete: Cascade)

  @@map("product_lead")
}

model ServiceLead {
  lead_id    Int      @id @default(autoincrement())
  service_id Int
  ip_address String?  @db.VarChar(45)
  country    String?  @db.VarChar(100)
  created_at DateTime @default(now()) @db.Timestamp(0)

  client_id  Int?
  client     Client?  @relation(fields: [client_id], references: [client_id], onDelete: SetNull)

  service Service @relation(fields: [service_id], references: [service_id], onDelete: Cascade)

  @@map("service_lead")
}

model Setting {
  key   String @id @db.VarChar(100)
  value String @db.Text
  
  @@map("setting")
}
